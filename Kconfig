menuconfig ZMK_BEHAVIOR_CLK_OR_KEY
    bool "Click-or-key behavior (Keyball44-style typing mode)"
    default y
    help
      Enable custom behavior that acts as a mouse click in mouse mode,
      but as a keyboard key in typing mode. Includes vowel auto-complete
      for Japanese romaji input.

if ZMK_BEHAVIOR_CLK_OR_KEY

choice ZMK_CLK_OR_KEY_PINCH_MODIFIER
    prompt "Modifier used for scroll + left-click pinch"
    default ZMK_CLK_OR_KEY_PINCH_MODIFIER_LGUI
    help
      Modifier held when left-click is pressed while scroll mode is active.
      The default keeps the current Mac/Figma pinch-zoom behavior.

config ZMK_CLK_OR_KEY_PINCH_MODIFIER_LGUI
    bool "Left GUI"

config ZMK_CLK_OR_KEY_PINCH_MODIFIER_LCTL
    bool "Left Control"

config ZMK_CLK_OR_KEY_PINCH_MODIFIER_LSFT
    bool "Left Shift"

config ZMK_CLK_OR_KEY_PINCH_MODIFIER_LALT
    bool "Left Alt"

endchoice

endif # ZMK_BEHAVIOR_CLK_OR_KEY

config ZMK_AML_TYPING_MODE_TIMEOUT
    int "AML typing mode vowel auto-complete timeout (ms)"
    default 300
    help
      Time window in milliseconds after a click where a vowel key will
      trigger auto-insertion of the preceding consonant (J/K/L).

menuconfig ZMK_BEHAVIOR_VOWEL_AUTO
    bool "Vowel autocomplete behavior (Keyball44 drag-scroll helper)"
    default y
    help
      Custom &kp wrapper for A/I/U/E/O that taps a recent J/K/L
      click-consonant via direct HID before raising the vowel event.

menuconfig ZMK_BEHAVIOR_BT_TOGGLE_01
    bool "BT profile toggle (0 <-> 1)"
    default y
    help
      Flip between BT profiles 0 and 1 on each activation. Handy for
      users who only rotate between two Bluetooth hosts.

menuconfig ZMK_BEHAVIOR_OS_AWARE
    bool "OS-aware key press behavior"
    default y
    help
      Picks one of two encoded keycodes to send based on the active BT
      profile (0 = Mac, others = Win/etc).

menuconfig ZMK_INPUT_PROCESSOR_TYPING_MODE_EXIT
    bool "Trackball motion typing-mode exit input processor"
    default y
    help
      Exit custom typing mode on REL_X/REL_Y trackball movement.

menuconfig ZMK_INPUT_PROCESSOR_SCROLL_MODE
    bool "Scroll-mode input processor (Keyball44 drag-scroll port)"
    default y
    help
      Convert trackball REL_X/REL_Y events into REL_HWHEEL/REL_WHEEL
      while the global scroll mode is active. Works with clk_or_key's
      scroll trigger (param2 = 0xFF) and fixed-scroll lock.

if ZMK_INPUT_PROCESSOR_SCROLL_MODE

config ZMK_SCROLL_MODE_DIVISOR_X
    int "Horizontal scroll divisor"
    default 50
    range 1 1000
    help
      Trackball motion units per horizontal scroll tick.

config ZMK_SCROLL_MODE_DIVISOR_Y
    int "Vertical scroll divisor"
    default 50
    range 1 1000
    help
      Trackball motion units per vertical scroll tick.

config ZMK_SCROLL_MODE_SNAP_BUFFER_LEN
    int "Scroll snap history length"
    default 5
    range 1 31
    help
      Number of recent samples used to decide the dominant scroll axis.

config ZMK_SCROLL_MODE_NATURAL_SCROLL
    bool "Use natural vertical scroll direction"
    default y
    help
      Match the current behavior: trackball down scrolls content down.

config ZMK_SCROLL_MODE_CLEAR_SUPPRESSED_ACCUM
    bool "Clear suppressed scroll-axis accumulator"
    default y
    help
      Clear the accumulator for the axis currently suppressed by scroll
      snap. Disable this to restore the previous behavior, where suppressed
      movement could accumulate and emit if the snap direction changed.

endif # ZMK_INPUT_PROCESSOR_SCROLL_MODE
